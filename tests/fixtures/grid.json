{
  "tests": [
    {
      "name": "container: creates a container table",
      "input": "<container></container>",
      "expected": "<table align=\"center\" class=\"container\"><tbody><tr><td></td></tr></tbody></table>"
    },
    {
      "name": "grid: creates a row",
      "input": "<row></row>",
      "expected": "<table class=\"row\"><tbody><tr></tr></tbody></table>"
    },
    {
      "name": "grid: creates a single column with first and last classes",
      "input": "<columns large=\"12\" small=\"12\">One</columns>",
      "expected": "<th class=\"small-12 large-12 columns first last\"><table><tbody><tr><th>One</th>\n<th class=\"expander\"></th></tr></tbody></table></th>"
    },
    {
      "name": "grid: single column with no-expander",
      "input": "<columns large=\"12\" small=\"12\" no-expander>One</columns>",
      "expected": "<th class=\"small-12 large-12 columns first last\"><table><tbody><tr><th>One</th></tr></tbody></table></th>"
    },
    {
      "name": "grid: single column with no-expander=\"false\"",
      "input": "<columns large=\"12\" small=\"12\" no-expander=\"false\">One</columns>",
      "expected": "<th class=\"small-12 large-12 columns first last\"><table><tbody><tr><th>One</th>\n<th class=\"expander\"></th></tr></tbody></table></th>"
    },
    {
      "name": "grid: single column with no-expander=\"true\"",
      "input": "<columns large=\"12\" small=\"12\" no-expander=\"true\">One</columns>",
      "expected": "<th class=\"small-12 large-12 columns first last\"><table><tbody><tr><th>One</th></tr></tbody></table></th>"
    },
    {
      "name": "grid: creates two columns, one first, one last",
      "input": "<columns large=\"6\" small=\"12\">One</columns><columns large=\"6\" small=\"12\">Two</columns>",
      "expected": "<th class=\"small-12 large-6 columns first\"><table><tbody><tr><th>One</th></tr></tbody></table></th><th class=\"small-12 large-6 columns last\"><table><tbody><tr><th>Two</th></tr></tbody></table></th>"
    },
    {
      "name": "grid: creates 3+ columns with correct first/last",
      "input": "<columns large=\"4\" small=\"12\">One</columns><columns large=\"4\" small=\"12\">Two</columns><columns large=\"4\" small=\"12\">Three</columns>",
      "expected": "<th class=\"small-12 large-4 columns first\"><table><tbody><tr><th>One</th></tr></tbody></table></th><th class=\"small-12 large-4 columns\"><table><tbody><tr><th>Two</th></tr></tbody></table></th><th class=\"small-12 large-4 columns last\"><table><tbody><tr><th>Three</th></tr></tbody></table></th>"
    },
    {
      "name": "grid: transfers classes to the final HTML",
      "input": "<columns class=\"small-offset-8 hide-for-small\">One</columns>",
      "expected": "<th class=\"small-offset-8 hide-for-small small-12 large-12 columns first last\"><table><tbody><tr><th>One</th>\n<th class=\"expander\"></th></tr></tbody></table></th>"
    },
    {
      "name": "grid: automatically assigns large from small if no large",
      "input": "<columns small=\"4\">One</columns><columns small=\"8\">Two</columns>",
      "expected": "<th class=\"small-4 large-4 columns first\"><table><tbody><tr><th>One</th></tr></tbody></table></th><th class=\"small-8 large-8 columns last\"><table><tbody><tr><th>Two</th></tr></tbody></table></th>"
    },
    {
      "name": "grid: automatically assigns small as full width if only large defined",
      "input": "<columns large=\"4\">One</columns><columns large=\"8\">Two</columns>",
      "expected": "<th class=\"small-12 large-4 columns first\"><table><tbody><tr><th>One</th></tr></tbody></table></th><th class=\"small-12 large-8 columns last\"><table><tbody><tr><th>Two</th></tr></tbody></table></th>"
    },
    {
      "name": "grid: supports nested grids",
      "input": "<row><columns><row></row></columns></row>",
      "expected": "<table class=\"row\"><tbody><tr><th class=\"small-12 large-12 columns first last\"><table><tbody><tr><th><table class=\"row\"><tbody><tr></tr></tbody></table></th></tr></tbody></table></th></tr></tbody></table>"
    },
    {
      "name": "block-grid: returns the correct block grid syntax",
      "input": "<block-grid up=\"4\"></block-grid>",
      "expected": "<table class=\"block-grid up-4\"><tbody><tr></tr></tbody></table>"
    },
    {
      "name": "block-grid: copies classes to the final HTML output",
      "input": "<block-grid up=\"4\" class=\"show-for-large\"></block-grid>",
      "expected": "<table class=\"block-grid up-4 show-for-large\"><tbody><tr></tr></tbody></table>"
    }
  ]
}
