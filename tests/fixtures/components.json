{
  "tests": [
    {
      "name": "button: creates a simple button",
      "input": "<button href=\"http://get.foundation\">Button</button>",
      "expected": "<table class=\"button\"><tbody><tr><td><table><tbody><tr><td><a href=\"http://get.foundation\">Button</a></td></tr></tbody></table></td></tr></tbody></table>"
    },
    {
      "name": "button: creates a button with target=\"_blank\" attribute",
      "input": "<button href=\"http://get.foundation\" target=\"_blank\">Button</button>",
      "expected": "<table class=\"button\"><tbody><tr><td><table><tbody><tr><td><a href=\"http://get.foundation\" target=_blank>Button</a></td></tr></tbody></table></td></tr></tbody></table>"
    },
    {
      "name": "button: creates a button with classes",
      "input": "<button class=\"small alert\" href=\"http://get.foundation\">Button</button>",
      "expected": "<table class=\"button small alert\"><tbody><tr><td><table><tbody><tr><td><a href=\"http://get.foundation\">Button</a></td></tr></tbody></table></td></tr></tbody></table>"
    },
    {
      "name": "button: creates a correct expanded button",
      "input": "<button class=\"expand\" href=\"http://get.foundation\">Button</button>",
      "expected": "<table class=\"button expand\"><tbody><tr><td><table><tbody><tr><td><center><a href=\"http://get.foundation\" align=\"center\" class=\"float-center\">Button</a></center></td></tr></tbody></table></td>\n<td class=\"expander\"></td></tr></tbody></table>"
    },
    {
      "name": "callout: creates a callout with correct syntax",
      "input": "<callout>Callout</callout>",
      "expected": "<table class=\"callout\"><tbody><tr><th class=\"callout-inner\">Callout</th><th class=\"expander\"></th></tr></tbody></table>"
    },
    {
      "name": "callout: copies classes to the final HTML",
      "input": "<callout class=\"primary\">Callout</callout>",
      "expected": "<table class=\"callout\"><tbody><tr><th class=\"callout-inner primary\">Callout</th><th class=\"expander\"></th></tr></tbody></table>"
    },
    {
      "name": "spacer: creates a spacer element with correct size",
      "input": "<spacer size=\"10\"></spacer>",
      "expected": "<table class=\"spacer\"><tbody><tr><td height=\"10\" style=\"font-size:10px;line-height:10px;\">&nbsp;</td></tr></tbody></table>"
    },
    {
      "name": "spacer: creates a spacer with a default size",
      "input": "<spacer></spacer>",
      "expected": "<table class=\"spacer\"><tbody><tr><td height=\"16\" style=\"font-size:16px;line-height:16px;\">&nbsp;</td></tr></tbody></table>"
    },
    {
      "name": "spacer: creates a spacer element for small screens",
      "input": "<spacer size-sm=\"10\"></spacer>",
      "expected": "<table class=\"spacer hide-for-large\"><tbody><tr><td height=\"10\" style=\"font-size:10px;line-height:10px;\">&nbsp;</td></tr></tbody></table>"
    },
    {
      "name": "spacer: creates a spacer element for large screens",
      "input": "<spacer size-lg=\"20\"></spacer>",
      "expected": "<table class=\"spacer show-for-large\"><tbody><tr><td height=\"20\" style=\"font-size:20px;line-height:20px;\">&nbsp;</td></tr></tbody></table>"
    },
    {
      "name": "spacer: creates a spacer for small and large screens",
      "input": "<spacer size-sm=\"10\" size-lg=\"20\"></spacer>",
      "expected": "<table class=\"spacer hide-for-large\"><tbody><tr><td height=\"10\" style=\"font-size:10px;line-height:10px;\">&nbsp;</td></tr></tbody></table><table class=\"spacer show-for-large\"><tbody><tr><td height=\"20\" style=\"font-size:20px;line-height:20px;\">&nbsp;</td></tr></tbody></table>"
    },
    {
      "name": "spacer: copies classes to the final spacer HTML",
      "input": "<spacer size=\"10\" class=\"bgcolor\"></spacer>",
      "expected": "<table class=\"spacer bgcolor\"><tbody><tr><td height=\"10\" style=\"font-size:10px;line-height:10px;\">&nbsp;</td></tr></tbody></table>"
    },
    {
      "name": "wrapper: creates a wrapper with classes",
      "input": "<wrapper class=\"header\"></wrapper>",
      "expected": "<table class=\"wrapper header\" align=\"center\"><tbody><tr><td class=\"wrapper-inner\"></td></tr></tbody></table>"
    },
    {
      "name": "h-line: creates a horizontal rule with classes",
      "input": "<h-line class=\"dotted\"></h-line>",
      "expected": "<table class=\"h-line dotted\"><tbody><tr><th>&nbsp;</th></tr></tbody></table>"
    },
    {
      "name": "menu: creates a menu with item tags inside",
      "input": "<menu><item href=\"http://get.foundation\">Item</item></menu>",
      "expected": "<table class=\"menu\"><tbody><tr><td><table><tbody><tr><th class=\"menu-item\"><a href=\"http://get.foundation\">Item</a></th></tr></tbody></table></td></tr></tbody></table>"
    },
    {
      "name": "menu: creates a menu with items with target attribute",
      "input": "<menu><item href=\"http://get.foundation\" target=\"_blank\">Item</item></menu>",
      "expected": "<table class=\"menu\"><tbody><tr><td><table><tbody><tr><th class=\"menu-item\"><a href=\"http://get.foundation\" target=_blank>Item</a></th></tr></tbody></table></td></tr></tbody></table>"
    },
    {
      "name": "menu: creates a menu with classes",
      "input": "<menu class=\"vertical\"></menu>",
      "expected": "<table class=\"menu vertical\"><tbody><tr><td><table><tbody><tr></tr></tbody></table></td></tr></tbody></table>"
    }
  ]
}
