{
  "tests": [
    {
      "name": "button inside container>row>column",
      "input": "<container><row><column><button href=\"#\">Click</button></column></row></container>",
      "expected": "<table role=\"presentation\" align=\"center\" class=\"container\"><tbody><tr><td><table role=\"presentation\" class=\"row\"><tbody><tr><th class=\"small-12 large-12 columns first last\"><table role=\"presentation\"><tbody><tr><th><table role=\"presentation\" class=\"button\"><tbody><tr><td><table role=\"presentation\"><tbody><tr><td><a href=\"#\">Click</a></td></tr></tbody></table></td></tr></tbody></table></th>\n<th class=\"expander\"></th></tr></tbody></table></th></tr></tbody></table></td></tr></tbody></table>"
    },
    {
      "name": "alert inside container>row>column",
      "input": "<container><row><column><alert type=\"warning\">Watch out!</alert></column></row></container>",
      "expected": "<table role=\"presentation\" align=\"center\" class=\"container\"><tbody><tr><td><table role=\"presentation\" class=\"row\"><tbody><tr><th class=\"small-12 large-12 columns first last\"><table role=\"presentation\"><tbody><tr><th><table role=\"presentation\" class=\"alert alert-warning\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tbody><tr><td style=\"padding: 12px 16px; background-color: #fcf8e3; border-radius: 4px;\">Watch out!</td></tr></tbody></table></th>\n<th class=\"expander\"></th></tr></tbody></table></th></tr></tbody></table></td></tr></tbody></table>"
    },
    {
      "name": "card inside container>row>column",
      "input": "<container><row><column><card title=\"Nested\">Inside a column</card></column></row></container>",
      "expected": "<table role=\"presentation\" align=\"center\" class=\"container\"><tbody><tr><td><table role=\"presentation\" class=\"row\"><tbody><tr><th class=\"small-12 large-12 columns first last\"><table role=\"presentation\"><tbody><tr><th><table role=\"presentation\" class=\"card\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border: 1px solid #e0e0e0; border-radius: 4px; overflow: hidden;\"><tbody><tr><td class=\"card-title\" style=\"padding: 16px 16px 0 16px; font-weight: bold; font-size: 18px;\">Nested</td></tr><tr><td class=\"card-body\" style=\"padding: 16px;\">Inside a column</td></tr></tbody></table></th>\n<th class=\"expander\"></th></tr></tbody></table></th></tr></tbody></table></td></tr></tbody></table>"
    },
    {
      "name": "badge inside button",
      "input": "<button href=\"#\">Buy Now <badge color=\"#e74c3c\">Sale</badge></button>",
      "expected": "<table role=\"presentation\" class=\"button\"><tbody><tr><td><table role=\"presentation\"><tbody><tr><td><a href=\"#\">Buy Now <span class=\"badge\" style=\"display: inline-block; padding: 2px 8px; background-color: #e74c3c; color: #ffffff; border-radius: 12px; font-size: 12px; font-weight: bold; line-height: 1.4;\">Sale</span></a></td></tr></tbody></table></td></tr></tbody></table>"
    },
    {
      "name": "blockquote inside container>row>column",
      "input": "<container><row><column><blockquote cite=\"Author\">Nested quote</blockquote></column></row></container>",
      "expected": "<table role=\"presentation\" align=\"center\" class=\"container\"><tbody><tr><td><table role=\"presentation\" class=\"row\"><tbody><tr><th class=\"small-12 large-12 columns first last\"><table role=\"presentation\"><tbody><tr><th><table role=\"presentation\" class=\"blockquote\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border-left: 4px solid #cccccc;\"><tbody><tr><td style=\"padding: 0 0 0 16px; font-style: italic;\">Nested quote</td></tr><tr><td style=\"padding: 8px 0 0 16px; font-size: 14px; color: #999999;\">&mdash; Author</td></tr></tbody></table></th>\n<th class=\"expander\"></th></tr></tbody></table></th></tr></tbody></table></td></tr></tbody></table>"
    },
    {
      "name": "multiple components with divider separator",
      "input": "<container><row><column><alert type=\"info\">Notice</alert><divider></divider><card>Content below</card></column></row></container>",
      "expected": "<table role=\"presentation\" align=\"center\" class=\"container\"><tbody><tr><td><table role=\"presentation\" class=\"row\"><tbody><tr><th class=\"small-12 large-12 columns first last\"><table role=\"presentation\"><tbody><tr><th><table role=\"presentation\" class=\"alert alert-info\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tbody><tr><td style=\"padding: 12px 16px; background-color: #d9edf7; border-radius: 4px;\">Notice</td></tr></tbody></table><table role=\"presentation\" class=\"divider\"><tbody><tr><th>&nbsp;</th></tr></tbody></table><table role=\"presentation\" class=\"card\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border: 1px solid #e0e0e0; border-radius: 4px; overflow: hidden;\"><tbody><tr><td class=\"card-body\" style=\"padding: 16px;\">Content below</td></tr></tbody></table></th>\n<th class=\"expander\"></th></tr></tbody></table></th></tr></tbody></table></td></tr></tbody></table>"
    },
    {
      "name": "hero with button inside",
      "input": "<hero background=\"bg.jpg\" width=\"600\" height=\"300\"><button href=\"#\">CTA</button></hero>",
      "expected": "<!--[if mso]>\n<v:rect xmlns:v=\"urn:schemas-microsoft-com:vml\" fill=\"true\" stroke=\"false\" style=\"width:600px;height:300px;\">\n<v:fill type=\"frame\" src=\"bg.jpg\" />\n<v:textbox style=\"mso-fit-shape-to-text:true\" inset=\"0,0,0,0\">\n<![endif]-->\n<table role=\"presentation\" class=\"hero\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-image: url('bg.jpg'); background-size: cover; background-position: center center; background-repeat: no-repeat; width: 600px;\"><tbody><tr><td style=\"padding: 0;\"><table role=\"presentation\" class=\"button\"><tbody><tr><td><table role=\"presentation\"><tbody><tr><td><a href=\"#\">CTA</a></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table>\n<!--[if mso]>\n</v:textbox>\n</v:rect>\n<![endif]-->"
    },
    {
      "name": "social inside wrapper",
      "input": "<wrapper><social align=\"center\"><social-link platform=\"facebook\" href=\"#\">FB</social-link></social></wrapper>",
      "expected": "<table role=\"presentation\" class=\"wrapper\" align=\"center\"><tbody><tr><td class=\"wrapper-inner\"><table role=\"presentation\" class=\"social\" align=\"center\"><tbody><tr><td><table role=\"presentation\" align=\"center\"><tbody><tr><td class=\"social-link facebook\" style=\"padding: 0 4px;\"><a href=\"#\" target=\"_blank\" style=\"color: #3b5998; text-decoration: none;\">FB</a></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table>"
    },
    {
      "name": "full email sequence: preview + container with button, spacer, divider",
      "input": "<preview>Hello</preview><container><row><column><button href=\"#\">Click</button><spacer height=\"10\"></spacer><divider></divider></column></row></container>",
      "expected": "<div style=\"display: none; max-height: 0; overflow: hidden; mso-hide: all;\">Hello</div><div style=\"display: none; max-height: 0; overflow: hidden; mso-hide: all;\">&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;</div><table role=\"presentation\" align=\"center\" class=\"container\"><tbody><tr><td><table role=\"presentation\" class=\"row\"><tbody><tr><th class=\"small-12 large-12 columns first last\"><table role=\"presentation\"><tbody><tr><th><table role=\"presentation\" class=\"button\"><tbody><tr><td><table role=\"presentation\"><tbody><tr><td><a href=\"#\">Click</a></td></tr></tbody></table></td></tr></tbody></table><table role=\"presentation\" class=\"spacer\"><tbody><tr><td height=\"10\" style=\"font-size:10px;line-height:10px;\">&nbsp;</td></tr></tbody></table><table role=\"presentation\" class=\"divider\"><tbody><tr><th>&nbsp;</th></tr></tbody></table></th>\n<th class=\"expander\"></th></tr></tbody></table></th></tr></tbody></table></td></tr></tbody></table>"
    }
  ]
}
